<!-- Halloween Logo Animation Script -->
<script>
(function() {
    let flickerInterval = null;
    
    // Funktion zur Überprüfung, ob wir in der Halloween-Periode sind
    function isHalloweenPeriod() {
        const now = new Date();
        const currentYear = now.getFullYear();
        
        // Startdatum: 1. Oktober des aktuellen Jahres
        const startDate = new Date(currentYear, 9, 1, 0, 0, 0);
        
        // Halloween Ende: 31. Oktober 23:59:59
        const halloween = new Date(currentYear, 9, 31, 23, 59, 59);
        
        return now >= startDate && now <= halloween;
    }
    
    // Funktion zur Überprüfung, ob Halloween vorbei ist (ab 1. November)
    function isAfterHalloween() {
        const now = new Date();
        const currentYear = now.getFullYear();
        const afterHalloween = new Date(currentYear, 10, 1, 0, 0, 0);
        
        return now >= afterHalloween;
    }
    
    // Funktion für den Flicker-Effekt (blendet Halloween-Logo ein)
    function flickerToHalloween() {
        const logoHalloween1 = document.getElementById('logoHalloween');
        const logoHalloween2 = document.getElementById('logoHalloween2');
        
        // Blende Halloween-Logo ein (600ms Einblendung)
        if (logoHalloween1) {
            logoHalloween1.style.opacity = 1;
            // Nach 600ms wieder ausblenden
            setTimeout(() => {
                logoHalloween1.style.opacity = 0;
            }, 4800);
        }
        
        if (logoHalloween2) {
            logoHalloween2.style.opacity = 1;
            setTimeout(() => {
                logoHalloween2.style.opacity = 0;
            }, 4800);
        }
    }
    
    // Funktion zum Setzen des finalen Zustands
    function setFinalState() {
        const logoHalloween1 = document.getElementById('logoHalloween');
        const logoHalloween2 = document.getElementById('logoHalloween2');
        
        if (isAfterHalloween()) {
            // Nach Halloween: Nur Standard-Logo (Halloween-Logo unsichtbar)
            if (logoHalloween1) logoHalloween1.style.opacity = 0;
            if (logoHalloween2) logoHalloween2.style.opacity = 0;
            
            // Stoppe Flicker-Interval
            if (flickerInterval) {
                clearInterval(flickerInterval);
                flickerInterval = null;
            }
        } else if (isHalloweenPeriod()) {
            const now = new Date();
            
            // Wenn wir am 31. Oktober sind
            if (now.getDate() === 31 && now.getMonth() === 9) {
                // Zeige Halloween-Logo permanent
                if (logoHalloween1) logoHalloween1.style.opacity = 1;
                if (logoHalloween2) logoHalloween2.style.opacity = 1;
                
                // Stoppe Flicker-Interval
                if (flickerInterval) {
                    clearInterval(flickerInterval);
                    flickerInterval = null;
                }
            } else {
                // Vor dem 31. Oktober: Standard-Logo mit Flicker-Effekt
                if (logoHalloween1) logoHalloween1.style.opacity = 0;
                if (logoHalloween2) logoHalloween2.style.opacity = 0;
                
                // Starte Flicker-Interval, falls noch nicht gestartet
                if (!flickerInterval) {
                    flickerInterval = setInterval(flickerToHalloween, 20000); // Alle 20 Sekunden
                }
            }
        } else {
            // Außerhalb der Halloween-Periode: Nur Standard-Logo
            if (logoHalloween1) logoHalloween1.style.opacity = 0;
            if (logoHalloween2) logoHalloween2.style.opacity = 0;
            
            // Stoppe Flicker-Interval
            if (flickerInterval) {
                clearInterval(flickerInterval);
                flickerInterval = null;
            }
        }
    }
    
    // Initiale Einstellung
    setFinalState();
    
    // Überprüfe den Status alle 30 Sekunden
    setInterval(setFinalState, 30000);
    
    // Überprüfe auch bei Sichtbarkeitswechsel (z.B. Tab-Wechsel)
    document.addEventListener('visibilitychange', function() {
        if (!document.hidden) {
            setFinalState();
        }
    });
})();
</script>

