[print_fax_order]
heading_checkout = 'Formulaire de commande de lettres'
text_checkout = 'Tu trouveras ci-dessous le formulaire de commande pour la commande manuelle de tes produits. Coche le mode de paiement et l\'option d\'exp&eacute;dition souhait&eacute;s et compl&egrave;te les informations manquantes. Imprime la commande et envoie-la nous. Nous te recommandons de ne pas joindre de monnaie, de cacher l\'argent liquide dans une enveloppe suppl&eacute;mentaire, un papier pli&eacute;, une carte postale ou entre deux cartons et d\'envoyer la lettre scell&eacute;e avec du ruban adh&eacute;sif suppl&eacute;mentaire en recommand&eacute; ! <br>  <br> Donn&eacute;es bancaires et DHL Packstation... <br> '
bank_daten = '<strong>Coordonn&eacute;es bancaires</strong><p>Nom de la banque : Raiffeisen Regionalbank Hall in Tirol<br>Destinataire : MRH N-Trade GmbH<br>Code bancaire : 36362<br>Num&eacute;ro de compte : 00000217968<br>IBAN : AT753636200000217968<br>BIC/SWIFT : RZTIAT22362<br>Motif du virement : DEIN-STRASSENNAME<br><br></p>'

text_checkout2 = '<strong>Envoi &agrave; des stations d\'emballage, veuillez remplir comme suit.</strong><br /> <img  width="350px" src="/images/icons/FAQ-%20Frage%20und%20Antwort.gif" alt="Packstation"> <br /><br /> Si vous avez des questions, notre support est &agrave; votre disposition au 0043 (0) 676 5124971 !<br><br>.'
